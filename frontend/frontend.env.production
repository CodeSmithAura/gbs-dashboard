# =============================================================================
# GBS Dashboard -- Frontend Production Environment
# Place this file at frontend\.env.production before running npm run build
# =============================================================================

# The browser calls the backend directly via IIS reverse proxy.
# IIS forwards /api/* and /health to the uvicorn backend on port 8000.
# This URL is what the browser sees -- keep it as localhost:3000 (IIS port).
VITE_API_BASE_URL=http://localhost:3000
