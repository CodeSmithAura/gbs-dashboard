# ── GBS Health Dashboard — POC Environment ───────────────────────────────────

# Database
POSTGRES_DB=gbs_health
POSTGRES_USER=gbs_user
POSTGRES_PASSWORD=gbs_pass
DATABASE_URL=postgresql://gbs_user:gbs_pass@db:5432/gbs_health

# Data source
DATA_SOURCE_TYPE=file
DATA_SOURCE_FORMAT=csv
DATA_SOURCE_PATH=/app/data/aruba_health.csv

# Polling
POLL_INTERVAL_SECONDS=60

# Demo mode — folder of snapshot CSVs, interval between each snapshot
DEMO_SAMPLES_PATH=/app/data/realtimesamples
DEMO_INTERVAL_SECONDS=30

# Phase 2 — Aruba API (leave blank for POC)
ARUBA_BASE_URL=
ARUBA_CLIENT_ID=
ARUBA_CLIENT_SECRET=
ARUBA_CUSTOMER_ID=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
