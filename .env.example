# ─── GBS Health Dashboard — POC Environment ─────────────────────────────────
# Copy this file to .env and adjust values as needed.
# Docker Compose reads .env automatically.

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=gbs_health
POSTGRES_USER=gbs_user
POSTGRES_PASSWORD=gbs_pass

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://gbs_user:gbs_pass@db:5432/gbs_health

# ── Data Source (Phase 1 — file-based) ───────────────────────────────────────
DATA_SOURCE_TYPE=file               # Change to "api" in Phase 2
DATA_SOURCE_FORMAT=csv              # "csv" or "json"
DATA_SOURCE_PATH=/app/data/aruba_health.csv

# ── Phase 2 — Aruba Central API (leave blank for POC) ────────────────────────
ARUBA_BASE_URL=
ARUBA_CLIENT_ID=
ARUBA_CLIENT_SECRET=
ARUBA_CUSTOMER_ID=

# ── Polling ───────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
