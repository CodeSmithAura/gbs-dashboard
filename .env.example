# =============================================================================
# GBS Service Health Dashboard -- Environment Configuration
# Windows Server + MS SQL Server + SolarWinds deployment
# Place this file at backend\.env
# No credentials should ever be committed to source control.
# =============================================================================

# ------ MS SQL Server ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
DB_HOST=<MSSQL_SERVER_IP_OR_HOSTNAME>
DB_PORT=1433
DB_NAME=gbs_health
DB_USER=gbs_app
DB_PASSWORD=<PASSWORD_FROM_SQL_TEAM>
DB_DRIVER=ODBC Driver 18 for SQL Server

# ------ Wireless data source (Aruba / CSV) ------------------------------------------------------------------------------------------------------------------------
DATA_SOURCE_TYPE=file
DATA_SOURCE_FORMAT=csv
DATA_SOURCE_PATH=C:/Users/karthikr/gbs/gbs-poc/data/aruba_health.csv
DEMO_SAMPLES_PATH=C:/Users/karthikr/gbs/gbs-poc/data/realtimesamples
POLL_INTERVAL_SECONDS=60
DEMO_INTERVAL_SECONDS=30

# Phase 2 Aruba API (leave blank until API access is granted)
ARUBA_BASE_URL=
ARUBA_CLIENT_ID=
ARUBA_CLIENT_SECRET=
ARUBA_CUSTOMER_ID=
ARUBA_REFRESH_TOKEN=<refresh_token_from_portal>

# ------ SolarWinds SWIS API ---------------------------------------------------------------------------------------------------------------------------------------------------------------------
SW_HOST=<SOLARWINDS_SERVER_IP_OR_HOSTNAME>
SW_PORT=17774
SW_USER=<READONLY_ORION_ACCOUNT>
SW_PASSWORD=<SOLARWINDS_PASSWORD>

# SW_VERIFY_SSL:
#   false        -- disable SSL verification (POC with self-signed cert)
#   /path/to.pem -- path to CA cert file (production with valid cert)
SW_VERIFY_SSL=false

# Custom property field name on Orion.Nodes holding the country value.
# Verify exact name in SWQL Studio: Orion.Nodes > CustomProperties
SW_COUNTRY_PROPERTY=Country

# Interface type to monitor. 6=Ethernet. Confirm in SWQL Studio.
SW_INTERFACE_TYPE=6

# Max alerts fetched per SolarWinds poll cycle (overrides dashboard_config)
SW_ALERT_LIMIT=100

# SolarWinds poll interval in seconds
SW_POLL_INTERVAL_SECONDS=60
