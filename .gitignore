# =============================================================================
# GBS Service Health Dashboard -- .gitignore
# =============================================================================

# ── Credentials -- NEVER commit these ────────────────────────────────────────
.env
*.env
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.coverage
*.egg-info/
dist/
build/
venv/
.venv/
*.log

# ── Node / React ──────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
*.tsbuildinfo
.eslintcache

# ── Data files -- contain real network data ───────────────────────────────────
data/aruba_health.csv
data/aruba_health_7day.csv
data/realtimesamples/*.csv
# Keep sample files tracked:
!data/aruba_health_sample.csv

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp

# ── Certificates -- never commit cert files ───────────────────────────────────
*.pem
*.crt
*.key
*.p12
*.pfx
